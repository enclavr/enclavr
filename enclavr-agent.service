[Unit]
Description=Enclavr Autonomous Agent
After=network.target

[Service]
Type=simple
WorkingDirectory=/home/dev/Projects/enclavr
Environment="PATH=/home/dev/.opencode/bin:/home/dev/go/bin:/home/dev/.bun/bin:/usr/local/bin:/usr/bin:/bin"
ExecStart=/usr/local/bin/enclavr-agent
Restart=always
RestartSec=10

[Install]
WantedBy=default.target
