[Unit]
Description=Enclavr Autonomous Agent
After=network.target

[Service]
Type=simple
User=dev
WorkingDirectory=/home/dev/Projects/enclavr
Environment="PATH=/home/dev/.opencode/bin:/usr/local/bin:/usr/bin:/bin"
ExecStart=/usr/local/bin/enclavr-agent
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
