+func NewAuthServiceWithEncryption(cfg *config.AuthConfig, encryptor *Encryptor) *AuthService {
+	return &AuthService{cfg: cfg, encryptor: encryptor}
+}
+
 func (s *AuthService) HashPassword(password string) (string, error) {
