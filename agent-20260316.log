+}
+
+func (s *AuthService) DecryptSecret(encryptedSecret string) (string, error) {
+	if s.encryptor == nil {
+		return encryptedSecret, nil
+	}
+	return s.encryptor.Decrypt(encryptedSecret)
+}
+
+func (s *AuthService) HasEncryptor() bool {
+	return s.encryptor != nil
