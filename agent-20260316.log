name: CI

on:
  schedule:
    - cron: '0 0 * * 0'  # Weekly on Sunday at midnight UTC
  workflow_dispatch:
  push:
    branches: [main]
    paths:
      - '.github/workflows/**'
  pull_request:
    branches: [main]

concurrency:
  group: ${{ github.workflow }}-${{ github.ref }}
  cancel-in-progress: true

jobs:
  validate-submodules:
    runs-on: ubuntu-latest

    steps:
      - uses: actions/checkout@v4
        with:
          fetch-depth: 0
          submodules: checkout
          token: ${{ secrets.GITHUB_TOKEN }}

      - name: Verify submodules
        run: |
          git submodule status

      - name: Check for submodule updates
        id: submodule_status
        run: |
          git diff --quiet HEAD..origin/main -- frontend server infra && echo "updated=false" || echo "updated=true"

      - name: Auto-update submodules if changed
        if: steps.submodule_status.outputs.updated == 'true'
        run: |
          git config --global user.email "enclavr.dev@gmail.com"
          git config --global user.name "Enclavr AI"
          git submodule update --remote --merge
          git add .
          git commit -m "chore: update submodules to latest" || echo "No submodule changes"
          git push https://x-access-token:${{ secrets.GITHUB_TOKEN }}@github.com/${{ github.repository }}.git HEAD:main
