+
+	User User `gorm:"foreignKey:UserID" json:"-"`
+	Room Room `gorm:"foreignKey:RoomID" json:"-"`
+}
+
+func (rb *RoomBookmark) BeforeCreate(tx *gorm.DB) error {
+	if rb.ID == uuid.Nil {
+		rb.ID = uuid.New()
+	}
+	if rb.CreatedAt.IsZero() {
+		rb.CreatedAt = time.Now()
+	}
+	return nil
+}
