# Database (Docker Compose)
POSTGRES_USER=enclavr
POSTGRES_PASSWORD=enclavr
POSTGRES_DB=enclavr

# Server
SERVER_PORT=8080
SERVER_READ_TIMEOUT=30s
SERVER_WRITE_TIMEOUT=30s

# Database (server connection)
DB_HOST=postgres
DB_PORT=5432
DB_USER=enclavr
DB_PASSWORD=enclavr
DB_NAME=enclavr
DB_SSLMODE=disable

# Authentication
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRATION=24h
REFRESH_EXPIRATION=168h

# OIDC (Optional - set OIDC_ENABLED=true and configure to use)
OIDC_ENABLED=false
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=

# Voice (WebRTC)
STUN_SERVER=stun:stun.l.google.com:19302
TURN_SERVER=turn:localhost:3478
TURN_USER=enclavr
TURN_PASS=enclavr
REALM=enclavr

# Redis (Optional - for horizontal scaling)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8080
