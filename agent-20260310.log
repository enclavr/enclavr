+.app-container {
+  display: flex;
+  height: 100vh;
+  background: #1a1a2e;
+  color: #eee;
+}
+
+.sidebar {
+  width: 250px;
+  background: #16213e;
+  display: flex;
+  flex-direction: column;
+  border-right: 1px solid #0f3460;
+}
+
+.sidebar-header {
+  padding: 16px;
+  border-bottom: 1px solid #0f3460;
+  font-size: 18px;
+  font-weight: bold;
+}
+
+.sidebar-content {
+  flex: 1;
+  padding: 16px;
+  overflow-y: auto;
+}
+
+.sidebar-nav-item {
+  padding: 10px 12px;
+  margin-bottom: 4px;
+  border-radius: 6px;
+  cursor: pointer;
+  transition: background 0.2s;
+}
+
+.sidebar-nav-item:hover {
+  background: #0f3460;
+}
+
+.sidebar-footer {
+  padding: 16px;
+  border-top: 1px solid #0f3460;
+}
+
+.user-account {
+  display: flex;
+  align-items: center;
+  gap: 10px;
+  padding: 10px;
+  border-radius: 6px;
+  cursor: pointer;
+  background: #0f3460;
+}
+
+.user-account:hover {
+  background: #1a4a7a;
+}
+
+.main-content {
+  flex: 1;
+  display: flex;
+  flex-direction: column;
+  background: #1a1a2e;
+}
+
+.main-header {
+  padding: 16px 24px;
+  border-bottom: 1px solid #0f3460;
+  font-size: 20px;
+  font-weight: 600;
+}
+
+.main-body {
+  flex: 1;
+  padding: 24px;
+  overflow-y: auto;
+}
+
+.chat-messages {
+  flex: 1;
+  overflow-y: auto;
+  padding: 16px;
+  margin-bottom: 16px;
+}
+
+.message {
+  padding: 8px 12px;
+  margin-bottom: 8px;
+  background: #16213e;
+  border-radius: 8px;
+}
+
+.chat-input-container {
+  padding: 16px 24px;
+  border-top: 1px solid #0f3460;
+  background: #16213e;
+}
+
+.chat-input-wrapper {
+  display: flex;
+  gap: 12px;
+}
+
+.chat-input {
+  flex: 1;
+  padding: 12px 16px;
+  border: 1px solid #0f3460;
+  border-radius: 8px;
+  background: #1a1a2e;
+  color: #eee;
+  font-size: 14px;
+}
+
+.chat-input:focus {
+  outline: none;
+  border-color: #4a90d9;
+}
+
+.send-button {
+  padding: 12px 24px;
+  background: #4a90d9;
+  color: white;
+  border: none;
+  border-radius: 8px;
+  cursor: pointer;
+  font-weight: 600;
+}
+
+.send-button:hover {
+  background: #3a7bc8;
+}
+
+.account-page {
+  padding: 24px;
+  max-width: 600px;
+}
+
+.account-header {
+  font-size: 24px;
+  font-weight: bold;
+  margin-bottom: 24px;
+}
+
+.account-field {
+  margin-bottom: 20px;
+}
+
+.account-label {
+  font-size: 12px;
+  color: #888;
+  margin-bottom: 4px;
+  text-transform: uppercase;
+}
+
+.account-value {
+  font-size: 16px;
+  padding: 12px;
+  background: #16213e;
+  border-radius: 6px;
+}
+
+.back-button {
+  padding: 8px 16px;
+  background: #0f3460;
+  color: #eee;
+  border: none;
+  border-radius: 6px;
+  cursor: pointer;
+  margin-bottom: 20px;
+}
+
+.back-button:hover {
+  background: #1a4a7a;
 }
