+		log.Printf("Failed to initialize Sentry: %v", err)
+		return
+	}
+
+	log.Printf("Sentry initialized with environment: %s, release: %s", cfg.Sentry.Environment, getReleaseVersion())
+}
+
+func getReleaseVersion() string {
+	version := os.Getenv("VERSION")
+	if version != "" {
+		return version
+	}
+	if commit := os.Getenv("COMMIT_SHA"); commit != "" {
+		return commit
+	}
+	return fmt.Sprintf("dev-%d", startTime.Unix())
+}
+
+func filterSentryEvent(event *sentry.Event, hint *sentry.EventHint) *sentry.Event {
+	if event.Request != nil {
+		if event.Request.URL == "/health" || event.Request.URL == "/status" || event.Request.URL == "/metrics" {
+			return nil
 		}
 	}
 
+	return event
+}
+
+func filterSentryTransaction(event *sentry.Event) *sentry.Event {
+	if event.Transaction == "" {
+		return nil
+	}
+
+	ignorePatterns := []string{
+		"GET /health",
+		"GET /status",
+		"GET /metrics",
+		"GET /debug/pprof",
+	}
+
+	for _, pattern := range ignorePatterns {
+		if event.Transaction == pattern {
+			return nil
+		}
+	}
+
+	return event
+}
+
+func captureErrorWithScope(scope *sentry.Scope, err error, msg string) {
+	if scope != nil {
+		scope.SetExtra("timestamp", time.Now().Unix())
+		sentry.CaptureException(err)
+	} else {
+		sentry.CaptureException(err)
+	}
+}
