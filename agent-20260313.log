+	h.activityMutex.Lock()
+	defer h.activityMutex.Unlock()
+
+	activity, exists := h.userActivities[userID]
+	if !exists {
+		activity = &RoomActivity{
+			UserID:   userID,
+			RoomID:   roomID,
+			Status:   "active",
+			JoinedAt: time.Now(),
+		}
+		h.userActivities[userID] = activity
+	}
