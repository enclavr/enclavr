+func (h *Hub) sendRoomStats(client *Client) {
+	stats := h.GetRoomStats(client.roomID)
+	payload, err := json.Marshal(stats)
+	if err != nil {
+		log.Printf("[Connection %s] Error marshaling room stats: %v", client.connectionID, err)
