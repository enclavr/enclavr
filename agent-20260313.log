+			return
+		case <-ticker.C:
+			h.mutex.RLock()
+			roomIDs := make([]uuid.UUID, 0, len(h.rooms))
+			for roomID := range h.rooms {
+				roomIDs = append(roomIDs, roomID)
+			}
