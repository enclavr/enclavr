+	case "away":
+		c.hub.setUserPresence(c.userID, c.roomID, "away")
+		awayMsg := &Message{
+			Type:      "user-away",
+			RoomID:    c.roomID,
+			UserID:    c.userID,
+			Timestamp: time.Now(),
+		}
+		c.hub.broadcastToRoom(c.roomID, awayMsg, c.userID)
