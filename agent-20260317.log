      STUN_SERVER: stun:stun.l.google.com:19302
      TURN_PASS: enclavr
      TURN_SERVER: ""
      TURN_USER: enclavr
      UPLOAD_DIR: ./uploads
      VAPID_PRIVATE_KEY: ""
      VAPID_PUBLIC_KEY: ""
      VAPID_SUBJECT: mailto:admin@enclavr.local
    networks:
      default: null
    ports:
      - mode: ingress
        target: 8080
        published: "8080"
        protocol: tcp
    restart: unless-stopped
    user: 1000:1000
    volumes:
      - type: volume
        source: server_uploads
        target: /app/uploads
        volume: {}
