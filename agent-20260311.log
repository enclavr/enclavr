+func (h *AuthHandler) ForgotPassword(w http.ResponseWriter, r *http.Request) {
+	var req ForgotPasswordRequest
+	if err := json.NewDecoder(r.Body).Decode(&req); err != nil {
+		http.Error(w, "Invalid request body", http.StatusBadRequest)
+		return
+	}
+
+	if req.Email == "" {
+		http.Error(w, "Email is required", http.StatusBadRequest)
+		return
+	}
+
+	var user models.User
+	if err := h.db.Where("email = ?", strings.ToLower(req.Email)).First(&user).Error; err != nil {
+		w.Header().Set("Content-Type", "application/json")
+		json.NewEncoder(w).Encode(map[string]string{"message": "If the email exists, a reset link will be sent"})
+		return
+	}
+
+	resetToken, err := h.authService.GeneratePasswordResetToken(user.ID)
+	if err != nil {
+		log.Printf("Failed to generate password reset token: %v", err)
+		http.Error(w, "Failed to generate reset token", http.StatusInternalServerError)
+		return
+	}
+
+	hashedToken, err := h.authService.HashPassword(resetToken)
+	if err != nil {
+		log.Printf("Failed to hash password reset token: %v", err)
+		http.Error(w, "Failed to process request", http.StatusInternalServerError)
+		return
+	}
+
+	expiresAt := time.Now().Add(1 * time.Hour)
+	passwordReset := models.PasswordReset{
+		UserID:    user.ID,
+		Token:     hashedToken,
+		ExpiresAt: expiresAt,
+	}
+
+	if err := h.db.Create(&passwordReset).Error; err != nil {
+		log.Printf("Failed to create password reset record: %v", err)
+		http.Error(w, "Failed to create reset record", http.StatusInternalServerError)
+		return
+	}
+
+	log.Printf("Password reset requested for user %s, token: %s", user.Email, resetToken)
+
+	w.Header().Set("Content-Type", "application/json")
+	json.NewEncoder(w).Encode(map[string]string{"message": "If the email exists, a reset link will be sent"})
+}
+
+func (h *AuthHandler) ResetPassword(w http.ResponseWriter, r *http.Request) {
+	var req ResetPasswordRequest
+	if err := json.NewDecoder(r.Body).Decode(&req); err != nil {
+		http.Error(w, "Invalid request body", http.StatusBadRequest)
+		return
+	}
+
+	if req.Token == "" || req.NewPassword == "" {
+		http.Error(w, "Token and new password are required", http.StatusBadRequest)
+		return
+	}
+
+	claims, err := h.authService.ValidatePasswordResetToken(req.Token)
+	if err != nil {
+		http.Error(w, "Invalid or expired token", http.StatusBadRequest)
+		return
+	}
+
+	var passwordReset models.PasswordReset
+	if err := h.db.Where("user_id = ? AND used = ?", claims.UserID, false).
+		Order("created_at DESC").First(&passwordReset).Error; err != nil {
+		http.Error(w, "Invalid or expired token", http.StatusBadRequest)
+		return
+	}
+
+	if time.Now().After(passwordReset.ExpiresAt) {
+		http.Error(w, "Token has expired", http.StatusBadRequest)
+		return
+	}
+
+	if !h.authService.CheckPassword(req.Token, passwordReset.Token) {
+		http.Error(w, "Invalid token", http.StatusBadRequest)
+		return
+	}
+
+	var user models.User
+	if err := h.db.First(&user, claims.UserID).Error; err != nil {
+		http.Error(w, "User not found", http.StatusNotFound)
+		return
+	}
+
+	if err := auth.ValidatePassword(req.NewPassword, user.Username, user.Email); err != nil {
+		http.Error(w, err.Error(), http.StatusBadRequest)
+		return
+	}
+
+	hashedPassword, err := h.authService.HashPassword(req.NewPassword)
+	if err != nil {
+		http.Error(w, "Failed to hash password", http.StatusInternalServerError)
+		return
+	}
+
+	if err := h.db.Model(&user).Update("password_hash", hashedPassword).Error; err != nil {
+		http.Error(w, "Failed to update password", http.StatusInternalServerError)
+		return
+	}
+
+	passwordReset.Used = true
+	h.db.Save(&passwordReset)
+
+	log.Printf("Password reset successful for user %s", user.Email)
+
+	w.Header().Set("Content-Type", "application/json")
+	json.NewEncoder(w).Encode(map[string]string{"message": "Password has been reset successfully"})
+}
+
+func (h *AuthHandler) ValidateResetToken(w http.ResponseWriter, r *http.Request) {
+	token := r.URL.Query().Get("token")
+	if token == "" {
+		http.Error(w, "Token is required", http.StatusBadRequest)
+		return
+	}
+
+	claims, err := h.authService.ValidatePasswordResetToken(token)
+	if err != nil {
+		w.Header().Set("Content-Type", "application/json")
+		json.NewEncoder(w).Encode(map[string]bool{"valid": false})
+		return
+	}
+
+	var passwordReset models.PasswordReset
+	if err := h.db.Where("user_id = ? AND used = ?", claims.UserID, false).
+		Order("created_at DESC").First(&passwordReset).Error; err != nil {
+		w.Header().Set("Content-Type", "application/json")
+		json.NewEncoder(w).Encode(map[string]bool{"valid": false})
+		return
+	}
+
+	if time.Now().After(passwordReset.ExpiresAt) {
+		w.Header().Set("Content-Type", "application/json")
+		json.NewEncoder(w).Encode(map[string]bool{"valid": false})
+		return
+	}
+
+	w.Header().Set("Content-Type", "application/json")
+	json.NewEncoder(w).Encode(map[string]bool{"valid": true})
+}
